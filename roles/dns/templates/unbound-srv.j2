# =============================================================================
# CACHE SIZING
# =============================================================================
# Rule of thumb: rrset-cache = 2x msg-cache, key-cache = msg-cache/2.
msg-cache-size: 128m
rrset-cache-size: 256m
key-cache-size: 64m
neg-cache-size: 32m

# Infrastructure cache (nameserver RTT, EDNS support, lame detection).
# Large size for tracking many upstream servers efficiently.
infra-cache-numhosts: 50000

# =============================================================================
# THREADING & CONCURRENCY
# =============================================================================
# 4096 queries per thread * 4 threads = 16384 concurrent queries max.
num-queries-per-thread: 4096
outgoing-range: 8192

# =============================================================================
# LATENCY OPTIMIZATION
# =============================================================================
# Prefetch entries before they expire to keep the cache hot.
prefetch: yes
prefetch-key: yes

# Keep probing nameserver infrastructure for optimal RTT selection.
infra-keep-probing: yes

# Serve stale/expired data immediately while refreshing in background.
# Evict stale entries after 1 hour if upstream cannot be reached.
serve-expired: yes
serve-expired-ttl: 3600
serve-expired-client-timeout: 0

# Cap negative TTL at 5 minutes.
cache-max-negative-ttl: 300

# =============================================================================
# NETWORK BUFFER OPTIMIZATION
# =============================================================================
tcp-idle-timeout: 600000

# =============================================================================
# PRIVACY PROTECTION
# =============================================================================
# Disable EDNS Client Subnet to prevent leaking client IP to upstream.
max-client-subnet-ipv4: 0
max-client-subnet-ipv6: 0

# =============================================================================
# INTERFACE BINDINGS
# =============================================================================
# Bind to all interfaces so Unbound answers on every LAN IP.
# Without this, Unbound defaults to 127.0.0.1 only.
# Access is still restricted by the access-control rules below.
interface: 0.0.0.0

# =============================================================================
# ACCESS CONTROL
# =============================================================================
# Default deny, then allow our networks
access-control: 0.0.0.0/0 refuse
access-control: ::0/0 refuse
access-control: 127.0.0.0/8 allow
access-control: ::1/128 allow
{% for vlan in network_vlans %}
{% if vlan.dhcp_start is defined %}
access-control: {{ vlan.subnet }} allow
{% endif %}
{% endfor %}
access-control: {{ tailscale_config.subnet }} allow

# =============================================================================
# SECURITY HARDENING
# =============================================================================
hide-trustanchor: yes
harden-algo-downgrade: yes
harden-large-queries: yes
harden-unknown-additional: yes

# Rate limiting. Protect against amplification and abuse.
ip-ratelimit: 1000
ratelimit: 1000

# =============================================================================
# DNSSEC SETTINGS
# =============================================================================
# Log DNSSEC validation failures for security monitoring.
val-log-level: 1

# =============================================================================
# LOGGING
# =============================================================================
log-servfail: yes

# =============================================================================
# LOCAL ZONES AND RECORDS
# =============================================================================
include: /etc/unbound/local-data.conf

# =============================================================================
# ADBLOCK INTEGRATION
# =============================================================================
include: /etc/unbound/unbound_adblock.conf
